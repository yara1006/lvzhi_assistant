# 应用
APP_NAME=legal-assistant-api
DEBUG=false
LOG_LEVEL=INFO

# CORS：逗号分隔的来源，如 http://localhost:5173,https://app.example.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# 腾讯元器 OpenAPI（Bearer = 智能体 appkey；assistant_id = 智能体 appid）
YUANQI_BASE_URL=https://yuanqi.tencent.com/openapi/v1/agent/chat/completions
YUANQI_API_KEY=
YUANQI_ASSISTANT_ID=
# 可选：按场景覆盖默认 assistant_id（不填则使用 YUANQI_ASSISTANT_ID）
# YUANQI_ASSISTANT_CHAT=
# YUANQI_ASSISTANT_CONTRACT_REVIEW=
# YUANQI_ASSISTANT_CLAUSE_SEARCH=
# YUANQI_ASSISTANT_CONTRACT_GENERATE=

# 法条检索专用智能体：接入法条检索 API 时使用
HUNYUAN_BASE_URL=https://open.hunyuan.tencent.com/openapi/v1/agent/chat/completions
HUNYUAN_API_KEY=
HUNYUAN_ASSISTANT_ID=
# 可选：按场景覆盖默认 assistant_id（不填则使用 HUNYUAN_ASSISTANT_ID）
# HUNYUAN_ASSISTANT_CLAUSE_SEARCH=

YUANQI_TIMEOUT_SECONDS=120
YUANQI_HTTP2=false

# MySQL 异步连接串（asyncmy）
# 示例：mysql+asyncmy://user:pass@127.0.0.1:3306/luzhi_assistant?charset=utf8mb4
DATABASE_URL=mysql+asyncmy://root:password@127.0.0.1:3306/luzhi_assistant?charset=utf8mb4

# 匿名访问落库时使用的用户 UUID（需在 users 表中存在，或由应用首次写入）
ANONYMOUS_USER_ID=00000000-0000-0000-0000-000000000099

# 鉴权（可选）
# 若设置 API_KEY，则请求 /api/v1/* 需带请求头：X-API-Key: <值>（健康检查等公开路由除外）
API_KEY=
# JWT（可选）：设置后可用 Authorization: Bearer <jwt>，载荷需含 sub 作为业务 user_id
JWT_SECRET=
JWT_ALGORITHM=HS256
# 登录接口：POST /api/v1/auth/login
# 登出接口：POST /api/v1/auth/logout

# 上传
MAX_UPLOAD_BYTES=20971520
